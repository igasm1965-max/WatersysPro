# MQTT broker used by backend
MQTT_BROKER=mqtts://esp32:Miv18072026@8bbebf26c27f4745a2dd39059872f9c3.s1.eu.hivemq.cloud:8883
MQTT_TOPIC_BASE=watersystem

# Disable demo fallback to show only real telemetry devices
DEMO_FALLBACK_ENABLED=false

# Postgres connection
PGHOST=postgres
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=watersys
PGPORT=5432

# Server port
PORT=3000

# Remote web control protection
# If REMOTE_REQUIRE_TOKEN=true, remote API requires header x-admin-token
REMOTE_REQUIRE_TOKEN=true
REMOTE_ADMIN_TOKEN=change_me_strong_token

# Expo push (optional)
EXPO_ACCESS_TOKEN=
