# MQTT broker used by backend (docker-compose sets mqtt://mosquitto:1883)
MQTT_BROKER=mqtt://mosquitto:1883
MQTT_TOPIC_BASE=watersystem

# Postgres connection
PGHOST=postgres
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=watersys
PGPORT=5432

# Server port
PORT=3000

# Remote web control protection
# If REMOTE_REQUIRE_TOKEN=true, remote API requires header x-admin-token
REMOTE_REQUIRE_TOKEN=true
REMOTE_ADMIN_TOKEN=change_me_strong_token

# Expo push (optional)
EXPO_ACCESS_TOKEN=
