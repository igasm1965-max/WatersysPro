/// Инициализация SD карты (SPI mode)
// flag set by initSD and used elsewhere (status reporting etc)
bool sdPresent = false;

// spinlock used to serialize access to SD/SPIFFS from different tasks
portMUX_TYPE sdMux = portMUX_INITIALIZER_UNLOCKED;

// keep a persistent SPIClass for SD operations; local instances can be destroyed
// by leaving the function, which would leave SD library holding a pointer to
// freed memory (leading to crashes later when beginTransaction is called).
static SPIClass sdSPI(VSPI);

bool initSD() {
  Serial.println(tr("[SD] Initialization (SPI)...", "[SD] Инициализация (SPI)..."));
  // nothing needed for spinlock; sdMux already statically initialized
  sdSPI.begin(SD_SCK_PIN, SD_MISO_PIN, SD_MOSI_PIN, SD_CS_PIN);
  if (!SD.begin(SD_CS_PIN, sdSPI)) {
    Serial.println(tr("[SD] mount failed (no card or wiring)", "[SD] монтаж не удался (нет карты или проводка)"));
    sdPresent = false;
    return false;
  }
  uint8_t t = SD.cardType();
  Serial.printf(tr("[SD] card mounted, type=%u\n", "[SD] карта смонтирована, тип=%u\n"), t);
  // migrate log format if the old binary file is still present on SPIFFS
  // or SD itself
  extern void migrateOldBinaryLog();
  migrateOldBinaryLog();

  // Try a small write/read test to verify filesystem
  File f = SD.open("/sd_test.txt", FILE_WRITE);
  if (f) {
    f.printf("sd инициализация ок: %lu\n", millis());
    f.close();
    Serial.println(tr("[SD] test file written", "[SD] тестовый файл записан"));
    sdPresent = true;
  } else {
    Serial.println(tr("[SD] test file write failed", "[SD] запись тестового файла не удалась"));
    sdPresent = false;
  }
  // after successful initialization, attempt to copy UI assets so that
  // they can later be served directly from the card and freed from SPIFFS.
  if (sdPresent) {
    migrateUiToSd();
  }
  return sdPresent;
}

/// Форматирует смонтированную SD карту.
bool formatSDCard() {
  if (!sdPresent) return false;
  // naive format: delete every file/dir under root
  File root = SD.open("/");
  if (!root) return false;
  bool success = true;
  File file = root.openNextFile();
  while (file) {
    String name = String(file.name());
    file.close();
    if (!SD.remove(name)) {
      Serial.printf(tr("[SD] failed to remove %s\n", "[SD] не удалось удалить %s\n"), name.c_str());
      success = false;
    }
    file = root.openNextFile();
  }
  root.close();
  if (success) Serial.println(tr("[SD] format (delete) successful", "[SD] форматирование (удаление) успешно"));
  else Serial.println(tr("[SD] format (delete) had errors", "[SD] форматирование (удаление) с ошибками"));
  return success;
}

