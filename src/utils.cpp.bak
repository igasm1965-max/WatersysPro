// ---------------------------------------------------------------------------
// File migration helpers
// ---------------------------------------------------------------------------

/// Copy UI-related static files from SPIFFS to SD card if they are absent or
/// outdated.  This allows the device to serve its web interface entirely from
/// the removable card and eventually eliminate the SPIFFS image altogether.
void migrateUiToSd() {
  if (!sdPresent) return;

  const char *files[] = {"/index.html", "/logfilter.html"};
  for (auto path : files) {
#if USE_SPIFFS
    if (!SPIFFS.exists(path))
      continue;

    // determine if we should copy: always overwrite if sizes differ
    size_t spiffsSize = 0;
    File srcProbe = SPIFFS.open(path, "r");
    if (srcProbe) {
      spiffsSize = srcProbe.size();
      srcProbe.close();
    }
    bool shouldCopy = true;
    if (SD.exists(path)) {
      File f = SD.open(path, "r");
      if (f) {
        size_t sdSize = f.size();
        f.close();
        if (sdSize == spiffsSize) {
          shouldCopy = false; // same size, assume up-to-date
        }
      }
    }

    if (!shouldCopy) continue;

    Serial.printf(tr("[SD] migrating %s from SPIFFS to SD (overwrite=%s)\n", "[SD] миграция %s из SPIFFS на SD (перезапись=%s)\n"), path, SD.exists(path) ? (isEnglish()?"yes":"да") : (isEnglish()?"no":"нет"));
    File src = SPIFFS.open(path, "r");
    File dst = SD.open(path, FILE_WRITE);
    if (src && dst) {
      if (dst.size() > 0) {
        // clear existing content
        SD.remove(path);
        dst = SD.open(path, FILE_WRITE);
      }
      while (src.available()) {
        dst.write(src.read());
      }
      dst.close();
      src.close();
    } else {
      Serial.printf(tr("[SD] failed to open %s for migration\n", "[SD] не удалось открыть %s для миграции\n"), path);
    }
#endif
  }
}

// ============ ПЕРЕЗАГРУЗКА СИСТЕМЫ ============

/// Мягкий сброс без сохранения (вызывается из меню)
void softReset() {
  Serial.println("[INFO] Soft reset requested");
  esp_restart();
}


// ============ УПРАВЛЕНИЕ LED/ИНДИКАТОРАМИ ============


// ============ РАБОТА С ПАМЯТЬЮ ============

/// Получает свободный объем памяти кучи (в байтах)
uint32_t getFreeHeap() {
  return esp_get_free_heap_size();
}

/// Получает размер наименьшего блока свободной памяти (в байтах)
uint32_t getMinFreeHeap() {
  return esp_get_minimum_free_heap_size();
}

/// Получает информацию о памяти в статическом буфере (без динамических String)
const char* getMemoryInfo() {
  static char buffer[100];
  snprintf(buffer, sizeof(buffer), "Куча: %u байт (мин: %u)",
           (unsigned) getFreeHeap(), (unsigned) getMinFreeHeap());
  return buffer;
}

/// Выводит информацию о памяти в Serial
void printMemoryInfo() {
  Serial.print("[ПАМ] ");
  Serial.println(getMemoryInfo());
}

/// Проверяет критически низкий объем памяти
bool isMemoryCritical() {
  return getFreeHeap() < 10000; // Менее 10KB
}

/// Удобная обёртка для проверки, истёк ли интервал от `start` (millis()).
/// Защищает от переполнения millis() при вычитании.
bool hasIntervalElapsed(unsigned long start, unsigned long intervalMs) {
  return (unsigned long)(millis() - start) > intervalMs;
}

// ============ РАБОТА СО СТРОКАМИ ============

/// Преобразует число в строку с лидирующими нулями
String formatNumber(int number, int digits) {
  String result = String(number);
  while (result.length() < digits) {
    result = "0" + result;
  }
  return result;
}

/// Преобразует число в время (MM:SS)
String formatTimeMM_SS(uint32_t seconds) {
  uint32_t minutes = seconds / 60;
  uint32_t secs = seconds % 60;
  
  return formatNumber(minutes, 2) + ":" + formatNumber(secs, 2);
}

/// Преобразует число в время (HH:MM:SS)
String formatTimeHH_MM_SS(uint32_t seconds) {
  uint32_t hours = seconds / 3600;
  uint32_t minutes = (seconds % 3600) / 60;
  uint32_t secs = seconds % 60;
  
  return formatNumber(hours, 2) + ":" + formatNumber(minutes, 2) + ":" + formatNumber(secs, 2);
}

// ============ ОТЛАДКА И ЛОГИРОВАНИЕ ============

/// Выводит информацию о версии системы
void printSystemVersion() {
  Serial.println(isEnglish() ? "\n=== System Information ===" : "\n=== Информация о системе ===");
  Serial.println(isEnglish() ? "Product: Water purification system" : "Продукт: Система очистки воды");
  Serial.println(isEnglish() ? "Version: 12.0" : "Версия: 12.0");
  Serial.println(isEnglish() ? "Platform: ESP32" : "Платформа: ESP32");
  Serial.print(isEnglish() ? "Build date: " : "Дата сборки: "); Serial.println(__DATE__ " " __TIME__);
  Serial.println(isEnglish() ? "===========================\n" : "===========================\n");
}

/// Выводит информацию о системе (память, время работы)
void printSystemStats() {
  Serial.println(isEnglish() ? "\n=== System status ===" : "\n=== Статус системы ===");
  printMemoryInfo();
  Serial.printf(isEnglish() ? "[TIME] Uptime: %s\n" : "[ВРЕМЯ] Время работы: %s\n",
    formatTimeHH_MM_SS(millis() / 1000).c_str());
  Serial.println(isEnglish() ? "=====================\n" : "=====================\n");
}

/// Выводит конфигурацию системы
void printConfiguration() {
  Serial.println(isEnglish() ? "\n=== Configuration ===" : "\n=== Конфигурация ===");
  Serial.printf(isEnglish() ? "Pins: PUMP=%d, PUMP2=%d, AERATION=%d\n" : "Пины: PUMP=%d, PUMP2=%d, AERATION=%d\n", PUMP_PIN, PUMP2_PIN, AERATION_PIN);
  Serial.printf(isEnglish() ? "      OZONE=%d, FILTER=%d, BACKWASH=%d\n" : "      OZONE=%d, FILTER=%d, BACKWASH=%d\n", OZONE_PIN, FILTER_PIN, BACKWASH_PIN);
  Serial.printf(isEnglish() ? "      ENCODER: CLK=%d, DT=%d, SW=%d\n" : "      ENCODER: CLK=%d, DT=%d, SW=%d\n", pinCLK, pinDT, pinSW);
  Serial.printf(isEnglish() ? "      SENSORS: TRIG1=%d, ECHO1=%d, TRIG2=%d, ECHO2=%d\n" : "      SENSORS: TRIG1=%d, ECHO1=%d, TRIG2=%d, ECHO2=%d\n",
    HC_TRIG1, HC_ECHO1, HC_TRIG2, HC_ECHO2);
  Serial.printf(isEnglish() ? "LCD: Addr=0x%02X, Cols=%d, Rows=%d\n" : "LCD: Адрес=0x%02X, Столбцы=%d, Строки=%d\n", LCD_ADDR, LCD_COLS, LCD_ROWS);
  Serial.println(isEnglish() ? "====================\n" : "====================\n");
}

/// Выводит все параметры системы для диагностики
void dumpFullDiagnostics() {
  printSystemVersion();
  printSystemStats();
  printConfiguration();
  printResetReason();
  // `printEventLogs()` удалена — для экспорта используйте exportEventsAsText()
}

