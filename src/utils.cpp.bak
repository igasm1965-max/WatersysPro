// helper for language selection
static bool langInitialized = false;
static bool langEnglish = true;

bool isEnglish() {
  if (!langInitialized) {
    langInitialized = true;
    extern Preferences preferences;
    if (preferences.isKey(PREF_KEY_LANG_EN)) {
      langEnglish = preferences.getBool(PREF_KEY_LANG_EN, true);
    }
  }
  return langEnglish;
}

bool setLanguageEnglish(bool eng) {
  bool old = isEnglish();
  langEnglish = eng;
  langInitialized = true;
  extern Preferences preferences;
  preferences.putBool(PREF_KEY_LANG_EN, eng);
  return old;
}

// choose appropriate string depending on language flag
static const char* tr(const char *en, const char *ru) {
  return isEnglish() ? en : ru;
}

