// ============ ФОРМАТИРОВАНИЕ И ВЫВОД ============

/// Форматирует и выводит логируемое сообщение
void logMessage(const char* level, const char* message) {
  extern RTC_DS3231 rtc;
  DateTime now = rtc.now();
  
  char timestamp[20];
  sprintf(timestamp, "[%02d:%02d:%02d] ",
    now.hour(), now.minute(), now.second());
  
  Serial.print(timestamp);
  Serial.print("[");
  Serial.print(level);
  Serial.print("] ");
  Serial.println(message);
}

/// Выводит сообщение об ошибке
void logError(const char* message) {
  logMessage("ОШИБКА", message);
}

/// Выводит информационное сообщение
void logInfo(const char* message) {
  logMessage("ИНФО", message);
}

/// Выводит сообщение отладки
void logDebug(const char* message) {
  logMessage("ОТЛАДКА", message);
}

/// Выводит предупреждение
void logWarning(const char* message) {
  logMessage("ПРЕДУПРЕЖДЕНИЕ", message);
}

// ============ ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ============

/// Заполняет массив `out[6]` байтами MAC (MSB-first)
void getMacBytes(uint8_t out[6]) {
  uint64_t mac = ESP.getEfuseMac();
  out[0] = (uint8_t)(mac >> 40);
  out[1] = (uint8_t)(mac >> 32);
  out[2] = (uint8_t)(mac >> 24);
  out[3] = (uint8_t)(mac >> 16);
  out[4] = (uint8_t)(mac >> 8);
  out[5] = (uint8_t)(mac);
}

/// Возвращает MAC-адрес устройства в виде строки (формат XX:XX:XX:XX:XX:XX)
String getMacString() {
  uint8_t b[6];
  getMacBytes(b);
  char buf[18];
  sprintf(buf, "%02X:%02X:%02X:%02X:%02X:%02X", b[0], b[1], b[2], b[3], b[4], b[5]);
  return String(buf);
}


/// Включение подсветки и дисплея (и сброс таймера простоя)
void activateBacklight() {
  extern SystemFlags flags;
  extern SafeLCD lcd;
  extern unsigned long lastActivityTime;
  
  lastActivityTime = millis();
  if (!flags.displayOn) {
    lcd.display();
    flags.displayOn = 1;
    flags.displayInitialized = 0;
  }
  if (!flags.backlightOn) {
    lcd.backlight();
    flags.backlightOn = 1;
  }
}

/// Выключение только подсветки
void deactivateBacklight() {
  extern SystemFlags flags;
  extern SafeLCD lcd;
  
  if (flags.backlightOn) {
    lcd.noBacklight();
    flags.backlightOn = 0;
  }
}

/// Обновляет подсветку дисплея
void updateBacklight() {
  extern SystemFlags flags;
  extern unsigned long backlightTimeout;
  extern unsigned long lastActivityTime;
  
  unsigned long currentTime = millis();
  
  // В меню, в режиме инфо по фильтру и в аварии подсветку принудительно держим включённой
  if (flags.inMenu || flags.inFilterWashInfo || flags.emergencyMode) {
    activateBacklight();
    return;
  }
  
  // Если включен ночной режим и сейчас ночь, используем минимальный таймаут
  unsigned long effectiveTimeout = backlightTimeout;
  if (flags.nightModeEnabled && isNightMode() && backlightTimeout == 0) {
    effectiveTimeout = 5 * 60 * 1000UL; // 5 минут в ночном режиме вместо 0
  }
  
  // Если задан таймаут подсветки (>0)
  if (effectiveTimeout > 0) {
    if (flags.backlightOn && hasIntervalElapsed(lastActivityTime, effectiveTimeout))
      deactivateBacklight();
  } else {
    // Если таймаут == 0, воспринимаем как «подсветка всегда включена»
    if (!flags.backlightOn)
      activateBacklight();
  }
}

/// Проверяет расписание и ночной режим
void checkSchedule() {
  extern SystemFlags flags;
  extern bool nightPauseActive;
  extern bool timeoutWasSaved;
  extern unsigned long savedBacklightTimeout;
  extern unsigned long backlightTimeout;
  extern bool isNightMode();
  extern bool isWithinSchedule();

  // Проверяем рабочее расписание
  bool withinSchedule = !flags.scheduleEnabled || isWithinSchedule();
  
  // Проверяем ночной режим (применяется ТОЛЬКО вне рабочего расписания или если расписание выключено)
  // Это предотвращает конфликт: ночной режим НЕ блокирует работу, если мы в рабочем расписании
  bool isNight = false;
  if (flags.nightModeEnabled && isNightMode()) {
    // Ночной режим применяется только если:
    // 1. Расписание выключено, ИЛИ
    // 2. Мы вне рабочего расписания
    isNight = !flags.scheduleEnabled || !withinSchedule;
  }
  
  // Пауза активна, если: вне рабочего расписания ИЛИ (ночь И расписание не активно)
  bool shouldPause = !withinSchedule || isNight;
  
  // Логируем изменение состояния паузы
  static bool lastPauseState = false;
  static bool lastNightState = false;
  
  if (shouldPause != lastPauseState || isNight != lastNightState) {
    if (shouldPause) {
      if (!withinSchedule) {
        Serial.println("[РАСПИСАНИЕ] Вне рабочего времени — пауза");
      } else if (isNight) {
        Serial.println("[РАСПИСАНИЕ] Пауза ночного режима активирована");
      }
    } else {
      Serial.println("[РАСПИСАНИЕ] Рабочее время возобновлено");
    }
    lastPauseState = shouldPause;
    lastNightState = isNight;
  }
  
  nightPauseActive = shouldPause;
  
  // Управление таймаутом подсветки в ночном режиме
  // Применяем уменьшенный таймаут если ночь И (расписание выключено ИЛИ вне расписания)
  if (flags.nightModeEnabled && isNightMode() && (!flags.scheduleEnabled || !withinSchedule)) {
    if (!timeoutWasSaved) {
      savedBacklightTimeout = backlightTimeout;
      backlightTimeout = 30 * 1000UL; // 30 секунд в ночном режиме
      timeoutWasSaved = true;
    }
  } else {
    if (timeoutWasSaved) {
      backlightTimeout = savedBacklightTimeout;
      timeoutWasSaved = false;
    }
  }
}
